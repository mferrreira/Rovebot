ROVEBOT_ENV=development

# LLM configuration
ROVEBOT_LLM_MODEL=claude-sonnet-4-20250514
ROVEBOT_ANTHROPIC_API_KEY=change-me
ROVEBOT_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# Gmail webhook and API
ROVEBOT_GMAIL_WEBHOOK_TOKEN=change-me
ROVEBOT_GMAIL_CLIENT_ID=change-me
ROVEBOT_GMAIL_CLIENT_SECRET=change-me
ROVEBOT_PUBSUB_AUDIENCE=http://localhost:3000/webhooks/gmail/pubsub
ROVEBOT_GMAIL_API_BASE_URL=https://gmail.googleapis.com/gmail/v1
ROVEBOT_GMAIL_ACCESS_TOKEN=change-me
ROVEBOT_GMAIL_POLLING=true  

# Sender identity
ROVEBOT_SENDER_NAME=change-me

# Slack app configuration
ROVEBOT_SLACK_BOT_TOKEN=change-me
ROVEBOT_SLACK_SIGNING_SECRET=change-me
ROVEBOT_SLACK_API_URL=https://slack.com/api/chat.postMessage
ROVEBOT_SLACK_CHANNEL=#ops-email-review

# Local knowledge base
ROVEBOT_KNOWLEDGE_DIR=knowledge
ROVEBOT_GMAIL_REFRESH_TOKEN=change-me
